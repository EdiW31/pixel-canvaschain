# Copy this file to .env and fill in values for your environment.
# .env is gitignored — never commit real credentials.

# MultiversX network config
VITE_CHAIN_ID=D
VITE_API_URL=https://devnet-api.multiversx.com
VITE_EXPLORER_URL=https://devnet-explorer.multiversx.com

# Smart contract address (devnet)
VITE_CONTRACT_ADDRESS=erd1qqqqqqqqqqqqqpgqm9vzcpflvanzyvd4nvrszq73njcspz0je52qady78z

# Backend WebSocket server
VITE_SERVER_URL=http://localhost:5001

# PIXEL ESDT token identifier
VITE_PIXEL_TOKEN_ID=PIXEL-xxxxxx

# Admin wallet address (owner of the smart contract)
VITE_ADMIN_ADDRESS=erd1...
